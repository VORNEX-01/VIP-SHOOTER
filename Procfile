web: sh -c "echo COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo NA); python -c \"import vip_shooter.settings as s; print('STATICFILES_DIRS=', s.STATICFILES_DIRS); print('STATIC_URL=', s.STATIC_URL)\"; python manage.py migrate --noinput && python manage.py collectstatic --noinput && gunicorn vip_shooter.wsgi:application --bind 0.0.0.0:$PORT --workers 1 --threads 2 --timeout 60"